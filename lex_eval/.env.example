# LexChat API Configuration
LEXCHAT_API=http://host.docker.internal:80

# Authentication
USERNAME=admin
PASSWORD=admin

# OpenAI judge (default provider)
OPENAI_API_KEY=yourkeyhere

# Gemini judge (alternative provider)
GEMINI_API_KEY=yourkeyhere
GEMINI_JUDGE_MODEL=gemini-2.0-flash

# Set to 'gemini' to use Gemini as the AI judge (default: openai)
JUDGE_PROVIDER=openai